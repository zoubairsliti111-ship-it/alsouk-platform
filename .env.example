# Supabase — public (browser-safe) credentials used by the supplier directory.
# Both must be set for the directory to load suppliers; without them the app
# shows an explicit error/empty state (there is no bundled mock fallback).
# Find these in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
# Use the publishable key, or the anon key if that's what your deployment
# provides (the Supabase→Vercel integration injects NEXT_PUBLIC_SUPABASE_ANON_KEY).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# RFQ admin view (server-only — NEVER prefix with NEXT_PUBLIC).
# The admin page at /admin/rfqs reads RLS-protected RFQ submissions with the
# service-role key (bypasses RLS) and is gated by a shared secret token.
# Both must be set for /admin/rfqs to show submissions. Find the service-role
# key in Supabase: Settings → API → service_role. Choose any strong token.
SUPABASE_SERVICE_ROLE_KEY=
RFQ_ADMIN_TOKEN=
