# Supabase — client-side (browser-exposed) configuration.
# Only use the anon/publishable key here. NEVER put the service_role
# key in a NEXT_PUBLIC_* variable: it bypasses Row Level Security and
# would be shipped to every visitor's browser.
# Make sure Row Level Security (RLS) is enabled on all Supabase tables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
