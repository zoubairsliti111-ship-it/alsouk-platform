# Supabase — public (browser-safe) credentials used by the supplier directory.
# When both are set the directory loads suppliers from Supabase; otherwise it
# falls back to the bundled static dataset so the app keeps working locally.
# Find these in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
